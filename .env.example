# Backend (copy to backend/.env or project root depending on where you start uvicorn)
DATABASE_URL=sqlite:///./pipeline.db
# Apify: https://console.apify.com/account/integrations — paste token below (never commit real tokens)
APIFY_TOKEN=
APIFY_ACTOR_ID=aimscrape~instagram-scraper
# Webhook that receives the JSON array after each run (empty = skip delivery)
DESTINATION_URL=
MAX_RESULTS_PER_QUERY=5
APIFY_TIMEOUT_SECS=300
DEDUPE_ENABLED=true
DESTINATION_RETRIES=3
PIPELINE_FAIL_CLOSED=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Max chars stored in Run.payload_preview (must stay valid JSON for UI)
PAYLOAD_PREVIEW_MAX_CHARS=1000000

# Redis + RQ: leave REDIS_URL empty to use FastAPI BackgroundTasks instead.
REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUE_NAME=pipeline

# Media: none | local | s3
MEDIA_STORAGE=none
MEDIA_LOCAL_ROOT=./media
# Base URL used in JSON payload video_url when MEDIA_STORAGE=local (must match how clients reach the API)
MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:8000
MAX_BYTES_PER_VIDEO=104857600
DOWNLOAD_TIMEOUT_SEC=120
MAX_CONCURRENT_DOWNLOADS=1

# S3 (only when MEDIA_STORAGE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=
